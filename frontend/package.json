{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "vitest": "npx vitest",
    "playwright": "npx playwright test",
    "wait-then-playwright": "./wait-for-rails.sh && npx playwright test",
    "rails-server": "cd ../backend && rails server",
    "front-and-back-dev": "concurrently -n 'BACKEND,FRONTEND' -c 'green,yellow' 'npm:rails-server' 'npm:dev'",
    "e2e-tests": "concurrently -n 'RAILS_SERVER,NUXT_SERVER,PLAYWRIGHT' -c 'blue,green,yellow' 'npm:rails-server' 'npm:dev' 'npm:wait-then-playwright'"
  },
  "dependencies": {
    "@playwright/test": "^1.47.2",
    "nuxt": "^3.13.0",
    "pixelmatch": "^6.0.0",
    "playwright-expect": "^0.1.2",
    "radix-vue": "^1.9.6",
    "tailwind-variants": "^0.2.1",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.7.3",
    "@flydotio/dockerfile": "^0.5.9",
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@iconify-json/lucide": "^1.2.7",
    "@nuxt/icon": "^1.5.2",
    "@nuxt/test-utils": "^3.14.2",
    "@nuxtjs/color-mode": "^3.5.1",
    "@nuxtjs/tailwindcss": "^6.12.1",
    "@tailwindcss/forms": "^0.5.9",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^11.1.0",
    "concurrently": "^9.0.1",
    "eslint": "^9.11.1",
    "happy-dom": "^15.7.4",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "wait-on": "^8.0.1"
  }
}
